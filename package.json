{
  "name": "snapsave",
  "version": "1.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.snapsave.app",
    "productName": "SnapSave",
    "directories": {
      "output": "dist-out"
    },
    "asar": true,
    "asarUnpack": [],
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": ["yt-dlp.exe", "ffmpeg.exe"]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "shortcutName": "SnapSave"
    },
    "publish": {
      "provider": "github",
      "owner": "theblackart001-bit",
      "repo": "snapsave"
    }
  }
}
